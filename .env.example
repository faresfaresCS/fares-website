# Copy to Vercel → Project → Settings → Environment Variables (never commit real values)

# Hyp Pay (formerly YaadPay) — https://developers.hyp.co.il/
HYP_API_URL=https://your-hyp-environment-url/xpo/Relay
HYP_API_USER=
HYP_API_PASSWORD=
HYP_TERMINAL_NUMBER=
HYP_MID=
HYP_MAC_KEY=

# Public site URL (no trailing slash) — used for success/error redirect URLs
SITE_URL=https://www.faresfares.online

# Order alerts via Resend — https://resend.com/
RESEND_API_KEY=
NOTIFY_EMAIL=orders@example.com
NOTIFY_FROM=פארס פארס <orders@yourdomain.com>
